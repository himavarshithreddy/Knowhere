{
  "name": "knowhere-server",
  "private": true,
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run mcp:build-widget",
    "dev": "tsx watch src/index.ts",
    "start": "node lib/index.js",
    "mcp:dev": "tsx watch src/mcp-server.ts",
    "mcp:start": "node lib/mcp-server.js",
    "mcp:build-widget": "node mcp-widget/build.js",
    "mcp:backfill": "tsx src/scripts/backfill-embeddings.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@knowhere/shared": "1.0.0",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vitejs/plugin-react": "6.0.2",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^14.0.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.5.1",
    "mongoose": "^8.10.1",
    "multer": "^2.2.0",
    "node-cron": "^4.2.1",
    "openai": "^6.44.0",
    "p-queue": "^9.3.0",
    "playwright": "^1.61.0",
    "vite": "8.0.16",
    "web-push": "^3.6.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.4",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.28.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
